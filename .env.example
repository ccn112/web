# ------------------------------------------------------------------
# X Web Platform — environment template
# Copy to .env and fill values. NEVER commit .env.
# ------------------------------------------------------------------

# --- Database (PostgreSQL) ---
# Matches docker-compose service `postgres`.
DATABASE_URL=postgres://xweb:xweb@localhost:5432/xweb

# --- Payload ---
# Long random string. Generate: openssl rand -base64 32
PAYLOAD_SECRET=change-me-please-generate-a-long-random-secret
# Public URL of the CMS (admin + REST/GraphQL API). In prod = the public CMS domain.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
# Schema management: unset in dev (auto-push). Set true ONLY for the first prod
# deploy to bootstrap tables, then set false and use `payload migrate`.
# PAYLOAD_DB_PUSH=false

# --- First admin user (created by the seed runner if it does not exist) ---
SEED_ADMIN_EMAIL=admin@x.vn
SEED_ADMIN_PASSWORD=Admin@12345

# --- Media storage (S3 / MinIO) ---
# When true, media uploads go to S3/MinIO. When false, files are stored on the local disk.
USE_S3=false
# When USE_S3=false on a PaaS (Coolify/Railway), the container FS is ephemeral — mount a
# persistent volume and point MEDIA_DIR at it (e.g. /app/media) so uploads survive redeploys.
# Leave unset in dev to use Payload's default local dir.
# MEDIA_DIR=/app/media
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=x-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# MinIO needs path-style access
S3_FORCE_PATH_STYLE=true

# --- Frontend (apps/clay public site) ---
# Server-side: clay proxies chat here (may be an internal host in prod).
CMS_URL=http://localhost:3000
# Browser-side: must be the PUBLIC CMS domain (used for next/image media URLs).
NEXT_PUBLIC_CMS_URL=http://localhost:3000
NODE_ENV=development
# Set true only if the CMS is on a private/loopback host without a public domain.
# ALLOW_LOCAL_IMAGE_IP=false

# --- Chat backend (CMS owns the keys; clay never calls the LLM) ---
# Provider: anthropic | openai | gemini | copilot. See docs/CHAT_PROVIDERS.md.
CHAT_PROVIDER=anthropic
# When ANTHROPIC_API_KEY is empty, the widget renders a safe demo state.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
# Other providers (fill the key to use; pick one via CHAT_PROVIDER)
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# COPILOT_TOKEN=
COPILOT_MODEL=openai/gpt-4o-mini
COPILOT_BASE_URL=https://models.github.ai/inference
# Cost controls
CHAT_RATE_LIMIT_PER_MINUTE=20
CHAT_ANON_DAILY_MAX=12
CHAT_REG_DAILY_MAX=60
